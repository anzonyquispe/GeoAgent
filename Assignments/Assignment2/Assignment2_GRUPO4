        "import netCDF4 as nc\n",
        "import rasterio\n",
        "from rasterio.transform import from_origin\n",
        "from rasterio.warp import reproject, Resampling\n",
        "\n",
        "# --- 1) leer el raster de clusters (UTM 18S, 100 m -> 1 ha por píxel) ---\n",
        "with rasterio.open(CLUSTERS_TIF) as src:\n",
        "    clusters = src.read(1)\n",
        "    clus_nodata = src.nodata\n",
        "    clus_transform = src.transform\n",
        "    clus_crs = src.crs\n",
        "    clus_profile = src.profile\n",
        "    px, py = src.res\n",
        "clus_shape = clusters.shape\n",
        "PIX_HA = (px * py) / 10000.0\n",
        "print(f'Píxel de cluster: {px:.0f} x {py:.0f} m -> {PIX_HA:.2f} ha')\n",
        "\n",
        "# --- 2) leer GloRice-I (NetCDF): variable 'area' = arroz en ha por celda ---\n",
        "ds = nc.Dataset(GLORICE_2019)\n",
        "raw = ds.variables['area'][:]                    # masked array (lat, lon)\n",
        "latv = np.array(ds.variables['lat'][:])          # 90 -> -90\n",
        "lonv = np.array(ds.variables['lon'][:])          # -180 -> 180\n",
        "ds.close()\n",
        "area_ha = np.nan_to_num(np.ma.filled(raw, np.nan).astype('float32'), nan=0.0)\n",
        "print('GloRice grid:', area_ha.shape, '| celdas con arroz en el mundo:', int((area_ha > 0).sum()))\n",
        "\n",
        "# --- 3) fracción de arroz por celda = área_arroz / área_celda ---\n",
        "res = abs(lonv[1] - lonv[0])                      # 1/12 grados\n",
        "cell_w_m = res * 111320.0 * np.cos(np.deg2rad(latv))   # ancho de celda por fila (varía con latitud)\n",
        "cell_h_m = res * 111320.0\n",
        "cell_area_ha = np.clip((cell_w_m * cell_h_m) / 10000.0, 1.0, None)   # (lat,)\n",
        "rice_frac = np.clip(area_ha / cell_area_ha[:, None], 0.0, 1.0).astype('float32')\n",
        "\n",
        "# georreferencia exacta de GloRice: origen (-180, 90), celdas de 'res' grados\n",
        "g_transform = from_origin(lonv[0], latv[0], res, res)\n",
        "\n",
        "# --- 4) reproyectar la fracción a la grilla de los clusters ---\n",
        "frac_aligned = np.zeros(clus_shape, dtype='float32')\n",
        "reproject(\n",
        "    source=rice_frac, destination=frac_aligned,\n",
        "    src_transform=g_transform, src_crs='EPSG:4326',\n",
        "    dst_transform=clus_transform, dst_crs=clus_crs,\n",
        "    resampling=Resampling.nearest,\n",
        ")\n",
        "\n",
        "# --- 5) métricas por cluster (las 3 que pide el enunciado) ---\n",
        "valido = clusters != (clus_nodata if clus_nodata is not None else -32768)\n",
        "filas = []\n",
        "for c in np.unique(clusters[valido]):\n",
        "    m = (clusters == c)\n",
        "    area_total = int(m.sum()) * PIX_HA\n",
        "    area_arroz = float(frac_aligned[m].sum() * PIX_HA)\n",
        "    filas.append({'cluster': int(c),\n",
        "                  'area_ha': round(area_total, 1),\n",
        "                  'area_arroz_ha': round(area_arroz, 1),\n",
        "                  'prop_arroz': round(area_arroz / area_total, 3) if area_total else 0.0})\n",
        "\n",
        "tabla = pd.DataFrame(filas).sort_values('prop_arroz', ascending=False).reset_index(drop=True)\n",
        "tabla['label'] = np.where(tabla['prop_arroz'] > 0.5, 'arroz', 'no_arroz')\n",
        "\n",
        "# plan B: si ningún cluster supera 50%, se etiqueta el de mayor proporción\n",
        "if (tabla['label'] == 'arroz').sum() == 0:\n",
        "    top = tabla['prop_arroz'].idxmax()\n",
        "    tabla.loc[top, 'label'] = 'arroz'\n",
        "    print(f\">> Plan B: ningún cluster supera 50%. Se etiqueta como ARROZ el de mayor proporción \"\n",
        "          f\"(cluster {int(tabla.loc[top,'cluster'])}, prop={tabla.loc[top,'prop_arroz']}).\")\n",
        "\n",
        "print('Fracción media de arroz sobre Bellavista:', round(float(frac_aligned[valido].mean()), 3))\n",
        "print('\\nMétricas por cluster:')\n",
        "tabla"
