      "source": [
        "import geopandas as gpd\n",
        "\n",
        "# fuegos -> GeoDataFrame en 4326 y luego a UTM 18S (CRS del raster de zonas)\n",
        "gf = gpd.GeoDataFrame(fires,\n",
        "                      geometry=gpd.points_from_xy(fires.longitude, fires.latitude),\n",
        "                      crs='EPSG:4326').to_crs('EPSG:32718')\n",
        "\n",
        "with rasterio.open(ZONE_TIF) as src:\n",
        "    zarr = src.read(1)\n",
        "    ztrans = src.transform\n",
        "    h, w = zarr.shape\n",
        "\n",
        "# coordenadas -> índices fila/columna (transformada inversa), igual que tu Parte 4\n",
        "inv = ~ztrans\n",
        "cols, rows = inv * (gf.geometry.x.values, gf.geometry.y.values)\n",
        "cols = np.floor(cols).astype(int)\n",
        "rows = np.floor(rows).astype(int)\n",
        "\n",
        "dentro = (rows >= 0) & (rows < h) & (cols >= 0) & (cols < w)\n",
        "zval = np.zeros(len(gf), dtype='uint8')\n",
        "zval[dentro] = zarr[rows[dentro], cols[dentro]]\n",
        "\n",
        "gf['zona_cod'] = zval\n",
        "gf_zonas = gf[gf.zona_cod.isin([1, 2])].copy()\n",
        "gf_zonas['zona'] = gf_zonas.zona_cod.map({1: 'arroz', 2: 'no_arroz'})\n",
        "\n",
        "print('Fuegos dentro de zonas de cultivo de Bellavista (2017-2019):', len(gf_zonas))\n",
        "print(gf_zonas.groupby(['year', 'zona']).size())"
      ],
