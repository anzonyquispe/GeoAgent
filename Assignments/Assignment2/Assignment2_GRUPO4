        "import requests, zipfile, io, os, glob\n",
        "\n",
        "# GloRice-I — área física de arroz (physical area). Si prefieres el 'In', usa el id 51211139.\n",
        "GLORICE_URL = 'https://ndownloader.figshare.com/files/51211142'  # GloRice-phsc-Ex.zip (~149 MB)\n",
